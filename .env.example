# Vercel: Project → Settings → Environment Variables (add Production and Preview as needed; redeploy after changes).
# Site
SITE_URL=https://stepweaver.dev

# API origin / host allowlists (production: set explicitly)
ALLOWED_ORIGINS=https://stepweaver.dev,https://www.stepweaver.dev
ALLOWED_HOSTS=stepweaver.dev,www.stepweaver.dev

# Notion CMS (Vercel: each variable must be enabled for Production if you deploy to stepweaver.dev — not only Preview/Development)
NOTION_API_KEY=
NOTION_BLOG_DB_ID=
NOTION_MESHTASTIC_DOCS_DB_ID=
# Comma-separated Notion page IDs allowed for POST /api/notion-blocks
NOTION_BLOCKS_ALLOWED_PAGE_IDS=
# HMAC secret for /api/notion-image signed tokens (generate a long random string)
NOTION_IMAGE_TOKEN_SECRET=

# AI Chat
GROQ_API_KEY=
OPENAI_API_KEY=
# Keep under Groq on-demand TPM; increase (up to ~95000) if you upgrade tier or rely on OpenAI fallback.
PORTFOLIO_KNOWLEDGE_MAX_CHARS=12000

# Weather (same name as v3)
NEXT_PUBLIC_OPENWEATHER_API_KEY=

# Email / contact form (same names as v3)
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=
SEND_CONFIRMATION_EMAIL=

# Book Shower (Google Apps Script); server-side proxy target
BOOK_SHOWER_SCRIPT_URL=
# Optional: override iframe URL in embed (defaults to same script as v3 if unset)
NEXT_PUBLIC_BOOK_SHOWER_SCRIPT_URL=

# Vercel KV (optional, for distributed rate limiting)
KV_REST_API_URL=
KV_REST_API_TOKEN=
